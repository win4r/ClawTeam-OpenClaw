# Normalize line endings
* text=auto

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# Python files
*.py text eol=lf
*.pyi text eol=lf

# TOML, YAML, JSON
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
